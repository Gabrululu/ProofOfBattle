{
  "expo": {
    "name": "Proof of Battle",
    "slug": "proof-of-battle",
    "version": "1.0.0",
    "scheme": "pob",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#05060D"
    },
    "android": {
      "package": "xyz.proofofbattle.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#05060D"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Proof of Battle to record voice commands for your robot."
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "bridgeUrl": "${EXPO_PUBLIC_BRIDGE_URL}",
      "eas": {
        "projectId": "789eb1cf-1c17-487d-a157-37aff8dc3ae9"
      },
      "router": {}
    },
    "owner": "gabrululus-organization",
    "ios": {
      "bundleIdentifier": "xyz.proofofbattle.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
