{
  "expo": {
    "name": "Proof of Battle",
    "slug": "proof-of-battle",
    "version": "1.0.0",
    "scheme": "pob",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "xyz.proofofbattle.mobile",
      "versionCode": 1
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "bridgeUrl": "${EXPO_PUBLIC_BRIDGE_URL}",
      "eas": {
        "projectId": "789eb1cf-1c17-487d-a157-37aff8dc3ae9"
      },
      "router": {}
    },
    "owner": "gabrululus-organization",
    "ios": {
      "bundleIdentifier": "xyz.proofofbattle.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
