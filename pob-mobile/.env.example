# ─────────────────────────────────────────────────────────────────────────────
# pob-mobile — Variables de entorno
#
# LOCAL (Expo Go / dev server)
#   → Copiar a .env y rellenar. Expo lee EXPO_PUBLIC_* automáticamente.
#
# EAS BUILD (preview / production)
#   → Las vars van en eas.json bajo "env" de cada perfil (ya configuradas).
#   → Para valores secretos usar: eas secret:create --name VAR --value VALUE
#
# IMPORTANTE: El prefijo EXPO_PUBLIC_ es obligatorio para que el valor
#   quede disponible en el bundle. Variables sin ese prefijo son ignoradas
#   por el runtime de Expo en React Native.
# ─────────────────────────────────────────────────────────────────────────────

# ── Bridge ────────────────────────────────────────────────────────────────────
# URL HTTP/HTTPS del bridge (Railway). Sin trailing slash.
# La app deriva wss:// automáticamente para el WebSocket.
#
# LOCAL (Expo Go con tunnel):  http://localhost:8000
# PRODUCCIÓN:                  https://tu-bridge.up.railway.app
EXPO_PUBLIC_BRIDGE_URL=https://your-bridge.up.railway.app

# ─────────────────────────────────────────────────────────────────────────────
# Las siguientes NO son variables de entorno — están hardcodeadas en el código
# porque son valores públicos o constantes del protocolo. Se documentan aquí
# solo como referencia.
#
#   PROGRAM_ID   = 9MFZtJWMutu1E6VDvKSJiDFEncidaoYvrsffr7U1MxCP  (lib/constants.ts)
#   RPC_ENDPOINT = https://api.devnet.solana.com                   (lib/constants.ts)
#   CLUSTER      = devnet                                           (useWallet.native.ts)
# ─────────────────────────────────────────────────────────────────────────────
