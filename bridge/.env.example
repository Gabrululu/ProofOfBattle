# ─────────────────────────────────────────────────────────────────────────────
# LOCAL (.env)  →  copia este archivo a .env y rellena los valores
# RAILWAY       →  agrega cada variable en Settings → Variables del proyecto
# ─────────────────────────────────────────────────────────────────────────────

# ── ElevenLabs ────────────────────────────────────────────────────────────────
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# ── Virtuals Protocol ─────────────────────────────────────────────────────────
# https://app.virtuals.io → Developer
VIRTUALS_API_KEY=your_virtuals_api_key_here
VIRTUALS_AGENT_ID=your_agent_id_here

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=9MFZtJWMutu1E6VDvKSJiDFEncidaoYvrsffr7U1MxCP

# LOCAL: ruta al keypair en disco
BRIDGE_KEYPAIR_PATH=~/.config/solana/id.json

# RAILWAY: pegar el contenido completo de ~/.config/solana/id.json como string
# Ejemplo: BRIDGE_KEYPAIR_JSON=[12,34,56,78,...]
BRIDGE_KEYPAIR_JSON=


# ── Webots (simulación local) ─────────────────────────────────────────────────
# LOCAL: dejar en 127.0.0.1:5005
# RAILWAY: usar el tunnel ngrok TCP que expone el puerto 5005 de tu máquina
#   1. Ejecutar: ngrok tcp 5005
#   2. Copiar host y puerto del resultado (ej: 0.tcp.ngrok.io y 19823)
WEBOTS_HOST=127.0.0.1
WEBOTS_PORT=5005
