# ── ElevenLabs ────────────────────────────────────────────────────────────────
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9

# ── Virtuals Protocol G.A.M.E. ───────────────────────────────────────────────
# GAME API key: https://console.game.virtuals.io → API Keys
# Key format: apt-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  (required for V2 SDK)
VIRTUALS_API_KEY=apt-your_game_api_key_here
# VIRTUALS_AGENT_ID is only used with legacy (non apt-) keys — leave blank otherwise
VIRTUALS_AGENT_ID=

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=9MFZtJWMutu1E6VDvKSJiDFEncidaoYvrsffr7U1MxCP

# LOCAL: ruta al keypair en disco
BRIDGE_KEYPAIR_PATH=~/.config/solana/id.json

# RAILWAY: pegar el contenido completo de ~/.config/solana/id.json como string
# Ejemplo: BRIDGE_KEYPAIR_JSON=[12,34,56,78,...]
BRIDGE_KEYPAIR_JSON=


# ── Webots (simulación) ───────────────────────────────────────────────────────
# OPCIÓN A — Local/Codespace (TCP directo):
WEBOTS_HOST=127.0.0.1
WEBOTS_PORT=5005

# OPCIÓN B — Railway con Cloudflare Tunnel (WebSocket:
#
#   En el Codespace, una sola vez:
#     curl -L https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 -o cloudflared && chmod +x cloudflared
#
#   Cada vez que arrancas Webots:
#     1. Abre Webots → Play  (levanta TCP en :5005)
#     2. python bridge/ws_bridge.py           (proxy WS→TCP en :5006)
#     3. ./cloudflared tunnel --url http://localhost:5006
#        → copia la URL  *.trycloudflare.com
#
#   En Railway → Variables:
#     WEBOTS_WS_URL=wss://tu-url.trycloudflare.com
#     (deja WEBOTS_HOST y WEBOTS_PORT con sus valores por defecto)
WEBOTS_WS_URL=
