# ─────────────────────────────────────────────────────────────────────────────
# LOCAL (.env)  →  copia este archivo a .env y rellena los valores
# VERCEL        →  agrega cada variable en Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Bridge WebSocket URL ──────────────────────────────────────────────────────
# LOCAL: dejar como ws://localhost:8000
# VERCEL: usar la URL de Railway con protocolo wss://
#   Ejemplo: wss://proof-of-battle-bridge.up.railway.app
VITE_BRIDGE_URL=ws://localhost:8000
